{
  "manifest_version": 3,
  "name": "Personio Attendance Autofill",
  "version": "1.0",
  "description": "Fill Arbeit (09:00-12:00 / 13:00-18:00) and Pause (12:00-13:00) for all working days in Personio monthly view",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["*://*.personio.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.personio.com/attendance/employee/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
